{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-project-state.sh",
            "statusMessage": "Loading project metrics..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=\"$TOOL_INPUT_FILE_PATH\"; if [ -n \"$file_path\" ] && echo \"$file_path\" | grep -qE '\\.(rs)$'; then cargo fmt --all 2>/dev/null; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=\"$TOOL_INPUT_FILE_PATH\"; if [ -n \"$file_path\" ] && echo \"$file_path\" | grep -qE '(pnpm-lock\\.yaml|package-lock\\.json|yarn\\.lock|Cargo\\.lock|\\.env)'; then echo 'BLOCK: Do not edit lock files or .env files directly. Use CLI tools (pnpm add, cargo add) for dependencies.' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/quality-gate.sh",
            "statusMessage": "Running quality gate..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo build:*)",
      "Bash(pnpm add:*)",
      "Bash(DOCMUX_UPDATE_EXPECTATIONS=1 cargo test -p docmux-cli --test golden)"
    ]
  }
}